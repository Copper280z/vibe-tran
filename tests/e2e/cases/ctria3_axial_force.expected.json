    },
    {
      "type": "node_displacement", "subcase": 1, "node_id": 3, "dof": "T1",
      "expected": 0.01, "rel_tol": 1e-6
    },
    {
      "comment": "Left-edge nodes fixed in x",
      "type": "node_displacement", "subcase": 1, "node_id": 1, "dof": "T1",
      "expected": 0.0, "abs_tol": 1e-12
    },
    {
      "type": "node_displacement", "subcase": 1, "node_id": 4, "dof": "T1",
