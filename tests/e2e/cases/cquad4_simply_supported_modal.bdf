$ cquad4_simply_supported_modal.bdf
$ Simply-supported beam: 10 CQUAD4 elements, L=1m, w=0.01m, t=0.01m
$ E=200 GPa, rho=7850 kg/m^3
$
$ Analytical first bending (simply-supported beam):
$   f1 = (pi/L)^2 * sqrt(EI/rhoA) / (2*pi)
$   I = w*t^3/12,  A = w*t  =>  EI/rhoA = E*t^2/(12*rho) = 212.3 m^4/s^2
$   f1 = pi^2/(2*pi*L^2) * sqrt(EI/rhoA) = pi/(2*L^2) * 14.57 ~= 22.9 Hz
SOL 103
CEND
SUBCASE 1
  LABEL = CQUAD4 SIMPLY SUPPORTED MODAL
  SPC = 1
  METHOD = 1
BEGIN BULK
MAT1,1,2.0000E+11,,,7850.0000
PSHELL,1,1,0.0100
EIGRL,1,0.0,,4

GRID,1,,0.0000,0.0,0.0
GRID,2,,0.0000,0.0100,0.0
GRID,3,,0.1000,0.0,0.0
GRID,4,,0.1000,0.0100,0.0
GRID,5,,0.2000,0.0,0.0
GRID,6,,0.2000,0.0100,0.0
GRID,7,,0.3000,0.0,0.0
GRID,8,,0.3000,0.0100,0.0
GRID,9,,0.4000,0.0,0.0
GRID,10,,0.4000,0.0100,0.0
GRID,11,,0.5000,0.0,0.0
GRID,12,,0.5000,0.0100,0.0
GRID,13,,0.6000,0.0,0.0
GRID,14,,0.6000,0.0100,0.0
GRID,15,,0.7000,0.0,0.0
GRID,16,,0.7000,0.0100,0.0
GRID,17,,0.8000,0.0,0.0
GRID,18,,0.8000,0.0100,0.0
GRID,19,,0.9000,0.0,0.0
GRID,20,,0.9000,0.0100,0.0
GRID,21,,1.0000,0.0,0.0
GRID,22,,1.0000,0.0100,0.0

CQUAD4,1,1,1,3,4,2
CQUAD4,2,1,3,5,6,4
CQUAD4,3,1,5,7,8,6
CQUAD4,4,1,7,9,10,8
CQUAD4,5,1,9,11,12,10
CQUAD4,6,1,11,13,14,12
CQUAD4,7,1,13,15,16,14
CQUAD4,8,1,15,17,18,16
CQUAD4,9,1,17,19,20,18
CQUAD4,10,1,19,21,22,20

$ Simply-supported: T1,T2,T3 fixed at left end; T2,T3 fixed at right end
SPC1,1,123,1,2
SPC1,1,23,21,22
ENDDATA
