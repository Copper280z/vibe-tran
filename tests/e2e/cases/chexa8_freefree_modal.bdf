$ chexa8_freefree_modal.bdf
$ Free-free bar: 5x1x1 CHEXA8, L=1m, a=0.01m square cross-section
$ E=200 GPa, rho=7850 kg/m^3, no boundary conditions
$
$ A free-free 3D solid has 6 rigid-body modes (f~0 Hz).
$ Analytical first elastic bending (free-free beam):
$   f7 = 4.730^2 * sqrt(EI/rhoA) / (2*pi*L^2) ~= 51.9 Hz
SOL 103
CEND
SUBCASE 1
  LABEL = CHEXA8 FREE-FREE MODAL
  METHOD = 1
BEGIN BULK
MAT1,1,2.0000E+11,,,7850.0000
PSOLID,1,1
EIGRL,1,0.0,,7

GRID,1,,0.0000,0.00000,0.00000
GRID,2,,0.2000,0.00000,0.00000
GRID,3,,0.4000,0.00000,0.00000
GRID,4,,0.6000,0.00000,0.00000
GRID,5,,0.8000,0.00000,0.00000
GRID,6,,1.0000,0.00000,0.00000
GRID,7,,0.0000,0.01000,0.00000
GRID,8,,0.2000,0.01000,0.00000
GRID,9,,0.4000,0.01000,0.00000
GRID,10,,0.6000,0.01000,0.00000
GRID,11,,0.8000,0.01000,0.00000
GRID,12,,1.0000,0.01000,0.00000
GRID,13,,0.0000,0.00000,0.01000
GRID,14,,0.2000,0.00000,0.01000
GRID,15,,0.4000,0.00000,0.01000
GRID,16,,0.6000,0.00000,0.01000
GRID,17,,0.8000,0.00000,0.01000
GRID,18,,1.0000,0.00000,0.01000
GRID,19,,0.0000,0.01000,0.01000
GRID,20,,0.2000,0.01000,0.01000
GRID,21,,0.4000,0.01000,0.01000
GRID,22,,0.6000,0.01000,0.01000
GRID,23,,0.8000,0.01000,0.01000
GRID,24,,1.0000,0.01000,0.01000

CHEXA,1,1,1,2,8,7,13,14,+
+,20,19
CHEXA,2,1,2,3,9,8,14,15,+
+,21,20
CHEXA,3,1,3,4,10,9,15,16,+
+,22,21
CHEXA,4,1,4,5,11,10,16,17,+
+,23,22
CHEXA,5,1,5,6,12,11,17,18,+
+,24,23
ENDDATA
