{
  "description": "CQUAD4 axial extension: δ = F*L/(E*A) = 1000*1/(1e6*0.1) = 0.01 m, σ_x = 10000 Pa",
  "checks": [
    {
      "comment": "Right-edge nodes should displace 0.01 m in +x (bilinear element is exact)",
      "type": "node_displacement", "subcase": 1, "node_id": 2, "dof": "T1",
      "expected": 0.01, "rel_tol": 1e-6
    },
    {
      "type": "node_displacement", "subcase": 1, "node_id": 3, "dof": "T1",
      "expected": 0.01, "rel_tol": 1e-6
    },
    {
      "comment": "Left-edge nodes fixed in x",
      "type": "node_displacement", "subcase": 1, "node_id": 1, "dof": "T1",
      "expected": 0.0, "abs_tol": 1e-12
    },
    {
      "type": "node_displacement", "subcase": 1, "node_id": 4, "dof": "T1",
      "expected": 0.0, "abs_tol": 1e-12
    },
    {
      "comment": "Membrane stress σ_x = F/A = 10000 Pa",
      "type": "element_stress", "subcase": 1, "elem_id": 1, "component": "sx",
      "expected": 10000.0, "rel_tol": 1e-6
    },
    {
      "comment": "σ_y = 0 (free Poisson contraction, plane stress)",
      "type": "element_stress", "subcase": 1, "elem_id": 1, "component": "sy",
      "expected": 0.0, "abs_tol": 1.0
    },
    {
      "comment": "σ_xy = 0 (pure axial load, no shear)",
      "type": "element_stress", "subcase": 1, "elem_id": 1, "component": "sxy",
      "expected": 0.0, "abs_tol": 1.0
    }
  ]
}
